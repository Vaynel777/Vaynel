{
  "buildCommand": "pip install -q fastapi uvicorn pydantic aiohttp python-multipart",
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
